IMAGE_TAG=local-deploy
AUTH_TYPE=basic
WEB_DOMAIN=https://onyx.metisdata.ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
USER_AUTH_SECRET=change-me
# Used by the BytePlus overlay; do not run the base compose with these host ports alone.
HOST_PORT=39000
HOST_PORT_80=39000
LOG_LEVEL=info
SESSION_EXPIRE_TIME_SECONDS=604800
DISABLE_VECTOR_DB=true
FILE_STORE_BACKEND=postgres
CACHE_BACKEND=postgres
AUTH_BACKEND=postgres
